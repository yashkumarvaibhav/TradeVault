[Unit]
Description=TradeVault Flask app (gunicorn :8011)
After=network-online.target
Wants=network-online.target

[Service]
Type=exec
WorkingDirectory=/home/siddhartha/TradeVault/app
EnvironmentFile=/home/siddhartha/TradeVault/app/.env
ExecStart=/home/siddhartha/TradeVault/app/.venv/bin/gunicorn -w 2 -b 127.0.0.1:8011 --access-logfile - --error-logfile - app:app
Restart=always
RestartSec=5
TimeoutStopSec=20

[Install]
WantedBy=default.target
