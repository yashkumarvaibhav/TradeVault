# Flask session secret (required in production)
SECRET_KEY=replace-with-a-long-random-secret

# Use true when serving HTTPS (production)
SESSION_COOKIE_SECURE=false

# Optional: Supabase/Postgres connection string (if set, this app uses Postgres)
# Example:
# DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# SQLite file path fallback (used only when DATABASE_URL is empty)
TRADEVAULT_DB_PATH=./trading_journal.db
