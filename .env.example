# PostgreSQL is self-hosted on the TradeVault VM. Never commit real credentials.
DATABASE_URL=postgresql://tradevault:change-me@127.0.0.1:5432/tradevault

# Better Auth (username + password). Secret must be >=32 chars: `openssl rand -base64 32`.
# BETTER_AUTH_URL is the public origin used for auth cookies/redirects.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-min-32-chars
BETTER_AUTH_URL=https://tradevault.yashkumarvaibhav.me

# Optional telemetry. When omitted, both integrations remain inert.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Legacy v1 variables remain local-only until the migration bridge is built.
SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=true
TRADEVAULT_DB_PATH=/absolute/path/to/trading_journal.db
