# better-auth lists @tanstack/react-start (vite >=7) as an OPTIONAL peer for the
# TanStack Start integration we do not use (this app is Next.js). Our vite is 6
# via vitest/Sentry, so npm's strict peer resolver errors on that unused optional
# peer. legacy-peer-deps keeps install/npm-ci consistent locally and in CI.
legacy-peer-deps=true
